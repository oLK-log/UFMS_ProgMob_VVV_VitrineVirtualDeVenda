<?xml version='1.0' encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FAFAFA">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cadastro"
        android:textSize="45sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:gravity="center"
        android:layout_marginBottom="24dp"
    />
    <ImageView
        android:id="@+id/imgFotoPerfil"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="center"
        android:background="#E0E0E0"
        android:layout_marginBottom="10dp"
    />
    <Button
        android:id="@+id/btnTirarFoto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Tirar Foto"
        android:layout_marginBottom="5dp"
    />
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:hint="Nome completo"
        app:endIconMode="clear_text"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"

        app:boxStrokeWidth="2dp"
        app:boxStrokeWidthFocused="3dp"
        app:boxStrokeColor="#212121"
        app:hintTextColor="#212121"
        android:textColorHint="#757575">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editNome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPersonName|textCapWords"
            android:textColor="#212121"/>

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:hint="E-mail"
        app:endIconMode="clear_text"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"

        app:boxStrokeWidth="2dp"
        app:boxStrokeWidthFocused="3dp"
        app:boxStrokeColor="#212121"
        app:hintTextColor="#212121"
        android:textColorHint="#757575">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:textColor="#212121"/>

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:hint="Senha"
        app:endIconMode="password_toggle"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"

        app:boxStrokeWidth="2dp"
        app:boxStrokeWidthFocused="3dp"
        app:boxStrokeColor="#212121"
        app:hintTextColor="#212121"
        android:textColorHint="#757575">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editSenha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:layout_marginBottom="6dp"
            android:textColor="#212121"/>

    </com.google.android.material.textfield.TextInputLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="0dp"
        android:paddingHorizontal="4dp">

        <TextView
            android:id="@+id/txtRegraTamanho"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Pelo menos 8 caracteres"
            android:textColor="#757575"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/txtRegraMaiuscula"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Pelo menos 1 letra maiúscula"
            android:textColor="#757575"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/txtRegraNumero"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Pelo menos 1 número"
            android:textColor="#757575"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/txtRegraEspecial"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• Pelo menos 1 caractere especial (@, #, $, etc.)"
            android:textColor="#757575"
            android:textSize="12sp"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Como você deseja usar esse App?"
        android:textColor="#757575"
        android:textSize="14sp"
        android:layout_marginTop="12sp"/>
    <RadioGroup
        android:id="@+id/rgTipoUsuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="5dp">
        <RadioButton
            android:id="@+id/rbCliente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sou Cliente"
            android:textStyle="bold"
            android:textColor="#212121"
            android:checked="true"/> <!--já deixa padrão como cliente-->
        <RadioButton
            android:id="@+id/rbLojista"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Sou Lojista"
            android:textStyle="bold"
            android:textColor="#212121"/>
    </RadioGroup>

    <Button
        android:id="@+id/btnCadastrar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Criar Conta"
        android:layout_marginTop="5dp"
        android:textSize="16sp"
    />

</LinearLayout>