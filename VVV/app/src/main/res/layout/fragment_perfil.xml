<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <TextView
        android:id="@+id/txtTituloAbaPerfil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="25dp"
        android:text="Meu Perfil"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:background="#FFFFFF"
        android:elevation="4dp" />

    <LinearLayout
        android:id="@+id/layoutDadosAbaPerfil"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/txtTituloAbaPerfil"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <androidx.cardview.widget.CardView
            android:layout_width="140dp"
            android:layout_height="140dp"
            app:cardCornerRadius="70dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="16dp">
            <ImageView
                android:id="@+id/imgAbaPerfil"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_camera" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/txtNomeAbaPerfil"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nome do Usuário"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#212121" />

        <TextView
            android:id="@+id/txtTipoPerfil"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de Usuário"
            android:textSize="16sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/layoutDadosAbaPerfil"
        android:layout_above="@+id/btnHistoricoPedidos"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="10dp"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/layoutDadosLojista"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Endereço da Loja"
                android:textColor="#212121"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/editEnderecoLojista"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ex: Av. Afonso Pena, Campo Grande"
                android:inputType="textPostalAddress"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cor Principal"
                android:textColor="#212121"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/editCorPrincipal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Ex: #135D66"
                    android:inputType="text" />
                <ImageButton
                    android:id="@+id/btnPaletaPrimaria"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:background="?attr/selectableItemBackground"
                    android:contentDescription="Escolher Cor na Paleta" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cor Secundária"
                android:textColor="#212121"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <EditText
                    android:id="@+id/editCorSecundaria"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Ex: #F0F0F0"
                    android:inputType="text" />

                <ImageButton
                    android:id="@+id/btnPaletaSecundaria"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:background="?attr/selectableItemBackground"
                    android:contentDescription="Escolher Cor na Paleta" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cor de Fundo da Vitrine"
                android:textColor="#212121"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">
                <EditText
                    android:id="@+id/editCorFundo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Ex: #F0F0F0"
                    android:inputType="text" />
                <ImageButton
                    android:id="@+id/btnPaletaFundo"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:background="?attr/selectableItemBackground"
                    android:contentDescription="Escolher Cor na Paleta" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSalvarDadosLojista"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Salvar Configurações"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnHistoricoPedidos"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_above="@id/btnSairSessao"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="8dp"
        android:text="Histórico de Pedidos"
        android:textSize="16sp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:strokeColor="#212121"
        android:textColor="#212121"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnSairSessao"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:text="@string/btn_sair"
        android:textSize="20sp"
        android:textStyle="bold"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF" />
</RelativeLayout>